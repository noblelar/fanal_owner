# This local API base URL lets the owner app reach the platform-auth endpoints during development.
FANAL_OWNER_API_BASE_URL=http://localhost:8081

# This session secret signs the owner app's httpOnly session cookie.
PLATFORM_OWNER_SESSION_SECRET=replace_with_a_long_random_secret

# This local port keeps the owner app separate from the main frontend during development.
PORT=3001
