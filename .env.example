# This API base URL points the owner app at the platform backend.
FANAL_OWNER_API_BASE_URL=http://localhost:8081

# This secret signs the owner app's httpOnly session cookie.
JWT_SECRET=replace_with_a_long_random_secret

# Set this to false only when the owner app is temporarily served over plain HTTP.
COOKIE_SECURE=true

# This local port keeps the owner app separate from the main frontend during development.
PORT=3001
